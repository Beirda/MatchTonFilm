# MatchTonFilm — variables d'environnement
# Copie ce fichier en `.env` à la racine puis renseigne tes propres valeurs.
# Toutes les clés sont préfixées EXPO_PUBLIC_ pour être lisibles côté client Expo.
# Ne commit jamais ton `.env` (il est déjà ignoré par .gitignore).

# --- Supabase ---------------------------------------------------------------
# Tableau de bord Supabase → Project Settings → Data API / API Keys
EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# --- TMDB -------------------------------------------------------------------
# https://www.themoviedb.org/settings/api → "API Read Access Token" (jeton v4,
# utilisé tel quel dans l'en-tête Authorization: Bearer ...).
EXPO_PUBLIC_TMDB_TOKEN=votre-jeton-de-lecture-tmdb-v4
